# TronGrid API key (optional, avoids rate limits)
# Get one at https://www.trongrid.io/
GOTRON_NODE_API_KEY=

# TRON gRPC node address (optional, defaults to network preset)
# GOTRON_MCP_NODE=grpc.trongrid.io:50051

# Use TLS for primary node (default: false, plaintext)
# GOTRON_MCP_TLS=false

# Fallback gRPC node (optional, auto-failover if primary is down)
# GOTRON_MCP_FALLBACK_NODE=grpc.trongrid.io:50051

# Use TLS for fallback node (default: false)
# GOTRON_MCP_FALLBACK_TLS=false

# Network: mainnet, nile, shasta (default: mainnet)
# GOTRON_MCP_NETWORK=mainnet

# HTTP authentication (hosted mode only)
# Bearer token for single-token auth
# GOTRON_MCP_AUTH_TOKEN=
# Path to file with bearer tokens (one per line, hot-reloaded)
# GOTRON_MCP_AUTH_TOKEN_FILE=

# Rate limiting (hosted mode only)
# Max requests per minute per IP (0 = unlimited, default: 0)
# GOTRON_MCP_RATE_LIMIT=60
# Trusted proxy mode for client IP detection: cloudflare, all, none (default: none)
# GOTRON_MCP_TRUSTED_PROXY=cloudflare
